# Язык интерфейса по умолчанию: ru или tr
# Varsayılan arayüz dili: ru veya tr
APP_LANGUAGE=ru

# Админка Streamlit
ADMIN_PASSWORD=change_me_strong_password

# Wialon Hosting API
WIALON_API_URL=https://hst-api.wialon.com
WIALON_TOKEN=PASTE_YOUR_WIALON_TOKEN_HERE

# Часовой пояс отчёта. Для Турции/Москвы обычно 3.
# Rapor saat dilimi. Türkiye/Moskova için genelde 3.
WIALON_TZ_HOURS=3

# Можно найти через web-интерфейс: админка → Wialon автоотчёт → Найти шаблоны и группы.
# Arayüzden bulunabilir: Admin → Wialon otomatik rapor → Şablonları ve grupları bul.
WIALON_REPORT_RESOURCE_ID=0
WIALON_REPORT_TEMPLATE_ID=0
WIALON_REPORT_OBJECT_ID=0

# Опционально: список объектов через запятую, если шаблон рассчитан на список ТС.
# Opsiyonel: şablon araç listesi bekliyorsa virgülle ayrılmış obje listesi.
WIALON_REPORT_OBJECT_ID_LIST=

# Поисковые маски для интерфейса.
# Arama maskeleri.
WIALON_REPORT_TEMPLATE_MASK=*Качество*
WIALON_OBJECT_MASK=*АВТОБУС*

# Для sync_wialon_once.py: сколько дней брать по умолчанию.
# sync_wialon_once.py için varsayılan gün sayısı.
WIALON_SYNC_DAYS=7
WIALON_REPORT_TIMEOUT_SEC=420
